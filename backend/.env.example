# Server Configuration
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/railway-management-system

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Admin Seeding
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123

# Email Configuration (Optional for development - will use simulated mode if not set)
# For production, configure Gmail App Password or another email provider
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
